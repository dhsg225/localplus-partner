{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/explainer/layout,_N_T_/explainer/page,_N_T_/explainer"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/explainer/__PAGE__",
    "/explainer",
    "/_index",
    "/_head"
  ]
}